# Copy to .env and fill in values for your local machine.

# Required when using OpenAI VLM/LLM features.
OPENAI_API_KEY=

# Tracker camera selection.
DANYA_TRACKER_CAMERA_INDEX=1
DANYA_TRACKER_CAMERA_CANDIDATES=1,0,2,3

# Set to 0/false/off to disable OpenAI image analysis.
DANYA_TRACKER_ENABLE_VLM=true
DANYA_TRACKER_OPENAI_MODEL=gpt-4o-mini

# Agent speech server used by the avatar bridge.
DANYA_SPEECH_SERVER=true
DANYA_SPEECH_SERVER_HOST=127.0.0.1
DANYA_SPEECH_SERVER_PORT=8765

# Agent LLM settings.
DANYA_LLM_MODEL=gpt-5-mini
DANYA_LLM_FALLBACK_MODELS=gpt-4.1-mini,gpt-4o-mini

# Agent timing settings.
DANYA_PERSON_EVENT_TTL_SEC=15
DANYA_CAMERA_SCENE_EVENT_TTL_SEC=35
DANYA_SPECIAL_SPEECH_INTERVAL=3

# Speech pacing estimation for AlterTalk2's own wait timing.
DANYA_SPEECH_WAIT_SCALE=1.0
DANYA_SPEECH_CHAR_SEC=0.13
DANYA_SPEECH_FIXED_OVERHEAD_SEC=1.5
DANYA_MIN_SPEECH_BUSY_SEC=3
DANYA_SPEECH_WAIT_MAX_SEC=60
